{
  "compilerOptions": {
    "module": "es6",
    "esModuleInterop": true,
    "target": "es6",
    "lib": ["es2020", "dom"],
    "rootDir": "src",
    "outDir": "./dist/client",
    "noImplicitAny": true,
    "sourceMap": true,
    "declaration": true,
    "skipLibCheck": true,
    "allowJs": true,
    "moduleResolution": "node",
    "baseUrl": "./",
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
